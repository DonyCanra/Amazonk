<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="./img/Asus-small.png" />
    <title>Document</title>

    <!-- Font awesome cdn link -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" />

    <style>
      section .heading {
        font-size: 3rem;
        text-align: center;
        padding-bottom: 30px;
      }
      section .content {
        display: flex;
      }
      section .content .image img{
        height: 80%;
        width: 80%;
      }
      section .content .info p {
        font-size: 30px;
      }
      span {
        font-weight: bolder;
      }
      
    </style>
  </head>

  <body>
    <section class="categories" id="categories">
      <div class="heading">
        <h1 class="heading">ASUS ROG STRIX G15 ~ NVIDIA GeForce RTX 3050</h1>
      </div>

      <div class="content">
        <div class="image">
          <img src="https://m.media-amazon.com/images/I/71pWcOnLL+L._AC_SX679_.jpg" alt="" />
        </div>
        <div class="info">
          <p><span>Brand</span>ASUS</p>
          <p><span>Series</span>ROG Strix G15</p>
          <p><span>Screen Size</span>15.6 Inches</p>
          <p><span>CPU Model</span>Ryzen 7</p>
          <p><span>Graphics Coprocessor</span> NVIDIA GeForce RTX 3050</p>
          <button class="btn btn-warning">Buy</button>
        </div>
      </div>
    </section>
  </body>
</html>